# DeepSeek API Key for the AI integration in project1 / project3.
# Get yours at https://platform.deepseek.com/
# Copy this file to .env.local and fill in your key.
#
# IMPORTANT: This variable has NO "NEXT_PUBLIC_" prefix, so it stays on the server
# (read via process.env inside src/app/api/** Route Handlers) and is never shipped
# to the browser. .env.local is git-ignored.
#
# When this is unset or the API call fails, both demos silently fall back to the
# built-in local rules and keep working.
DEEPSEEK_API_KEY=
